# ============================================
# ARTKUBUS BACKEND ENVIRONMENT CONFIGURATION
# ============================================
# SECURITY WARNING: Never commit .env files with real credentials to version control!
# Copy this file to .env and replace ALL placeholder values with real credentials.

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=3000

# API Base URL - Auto-configured based on NODE_ENV:
#   development: http://localhost:3000
#   production: https://api.kubus.site
# Override by setting HTTP_BASE_URL explicitly if needed
HTTP_BASE_URL=https://api.kubus.site

HTTP_STORAGE_PATH=./uploads

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# SECURITY: Use a strong password (minimum 32 characters, mixed case, numbers, symbols)
DB_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD_MIN_32_CHARS
DATABASE_URL=postgresql://artkubus:CHANGE_THIS_TO_SECURE_PASSWORD_MIN_32_CHARS@postgres:5432/artkubus

# For cPanel/VPS deployment:
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# ============================================
# REDIS (Caching & Sessions)
# ============================================
REDIS_URL=redis://redis:6379
# For cPanel: REDIS_URL=redis://localhost:6379

# ============================================
# IPFS CONFIGURATION (PINATA RECOMMENDED)
# ============================================
# Get API keys from: https://app.pinata.cloud/keys
# CRITICAL: Store these securely - they allow uploading to your IPFS account!
PINATA_API_KEY=YOUR_PINATA_API_KEY_HERE
PINATA_SECRET=YOUR_PINATA_SECRET_KEY_HERE

# IPFS Gateways (comma-separated, tries in order)
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/,https://ipfs.io/ipfs/,https://cloudflare-ipfs.com/ipfs/
IPFS_API_URL=https://api.pinata.cloud

# ============================================
# S3-COMPATIBLE STORAGE (OPTIONAL)
# ============================================
S3_ENABLED=false
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=artkubus-uploads
S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_S3_SECRET_KEY
S3_REGION=us-east-1

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
# CRITICAL: Generate secure random keys!
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Generate ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=CHANGE_THIS_GENERATE_WITH_CRYPTO_RANDOMBYTES_64
JWT_EXPIRES_IN=7d

ENCRYPTION_KEY=CHANGE_THIS_GENERATE_WITH_CRYPTO_RANDOMBYTES_32

# API Keys for service-to-service auth (comma-separated)
API_KEYS=

# ============================================
# CORS (CROSS-ORIGIN RESOURCE SHARING)
# ============================================
# Comma-separated allowed origins
# NEVER use '*' in production!
CORS_ORIGIN=https://art-kubus.io,https://app.art-kubus.io,https://www.art-kubus.io

# ============================================
# STORAGE PROVIDER CONFIGURATION
# ============================================
# Options:
#   - ipfs: IPFS only (requires Pinata credentials)
#   - http: Traditional HTTP storage only
#   - hybrid: Try IPFS first, fallback to HTTP (RECOMMENDED FOR PRODUCTION)
DEFAULT_STORAGE_PROVIDER=hybrid

# Feature flags
ENABLE_IPFS=true
ENABLE_HTTP_STORAGE=true
ENABLE_WEBSOCKETS=true
ENABLE_ANALYTICS=true

# Mock Data (Development/Testing)
# Set to 'true' to enable /api/mock/* endpoints
# SECURITY: NEVER enable in production - use only for development/testing
USE_MOCK_DATA=true

# ============================================
# UPLOAD LIMITS
# ============================================
MAX_UPLOAD_SIZE=52428800
JSON_LIMIT=10mb
URL_LIMIT=10mb

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=.glb,.gltf,.usdz,.jpg,.jpeg,.png,.webp

# ============================================
# RATE LIMITING (DDoS PROTECTION)
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
UPLOAD_RATE_LIMIT=50

# Per-IP limits for anonymous users
ANON_RATE_LIMIT=50

# Per-user limits for authenticated users
AUTH_RATE_LIMIT=1000

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
ENABLE_METRICS=true

# Sentry Error Tracking (optional but recommended)
# Get DSN from: https://sentry.io
SENTRY_DSN=

# ============================================
# EMAIL (OPTIONAL - FOR NOTIFICATIONS)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=info@kubus.site

# ============================================
# DEPLOYMENT INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Generate secure keys (see instructions above)
# 3. Set NODE_ENV=production
# 4. Configure database credentials
# 5. Add Pinata API keys for IPFS support
# 6. Set allowed CORS origins
# 7. Never commit .env to git (add to .gitignore)
# 8. Regularly rotate JWT_SECRET and ENCRYPTION_KEY
# 9. Use HTTPS in production (Nginx reverse proxy)
# 10. Enable firewall and security headers
