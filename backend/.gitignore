# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ==========================================
# ENVIRONMENT & SECRETS (CRITICAL!)
# ==========================================
.env
.env.local
.env.production
.env.staging
.env.*.local
*.key
*.pem
*.p12

# API Keys and secrets
**/api-keys.json
**/secrets.json
**/credentials.json

# ==========================================
