# Local development defaults for docker-compose.dev.yml
# Copy to `.env` in repo root and adjust as needed.

# Core services
POSTGRES_DB=artkubus
POSTGRES_USER=artkubus
DB_PASSWORD=artkubus_dev
JWT_SECRET=artkubus_dev_jwt_secret
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=3000

# Backend runtime
NODE_ENV=development
CORS_ORIGIN=http://localhost,http://127.0.0.1,http://[::1]
ADMIN_CORS_ORIGIN=
HTTP_BASE_URL=http://localhost:3000
APP_BASE_URL=http://localhost:8080
USE_MOCK_DATA=false
ORBITDB_AUTO_INIT=false
ORBITDB_SYNC_MODE=off
CACHE_ENABLED=true
CACHE_DRIVER=redis
CACHE_DEFAULT_TTL=90
ENABLE_DEBUG_ENDPOINTS=true
FEATURE_ENABLE_MEDIA_PROXY=true

# Auth providers
ENABLE_WALLET_AUTH=true
ENABLE_EMAIL_AUTH=true
ENABLE_GOOGLE_AUTH=true
GOOGLE_CLIENT_IDS=
GOOGLE_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_OCTOPUS_API_KEY=dev_email_octopus_key
EMAIL_OCTOPUS_WAITLIST_LIST_ID=dev_waitlist
EMAIL_OCTOPUS_NEWSLETTER_LIST_ID=dev_newsletter
EMAIL_OCTOPUS_SUBDOMAIN=api

# Flutter run examples
# Web E2E build (desktop/mobile emulation):
# flutter run -d chrome --web-port=8080 \
#   --dart-define=BACKEND_BASE_URL=http://localhost:3000 \
#   --dart-define=E2E=true
#
# Android emulator build:
# flutter run -d emulator-5554 \
#   --dart-define=BACKEND_BASE_URL=http://10.0.2.2:3000
#
# Android device build (replace host IP):
# flutter run -d <device-id> \
#   --dart-define=BACKEND_BASE_URL=http://192.168.1.10:3000
