<IfModule mod_headers.c>
  # Keep the renderer's stricter CSP on proxied public HTML. Static Flutter
  # responses do not set one, so they receive the established app policy.
  Header setifempty Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://fonts.googleapis.com https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https: wss: blob:; media-src 'self' blob: data: https:; worker-src 'self' blob:; object-src 'none'; frame-src 'self' https://accounts.google.com;"

  # --- Caching ---------------------------------------------------------------
  # LiteSpeed defaults to "Cache-Control: private", which prevents any CDN/edge
  # caching and offers no benefit to repeat visits. Override explicitly.
  #
  # App entry points + version manifests must ALWAYS revalidate so a new deploy
  # is picked up immediately (prevents the classic "stale main.dart.js after
  # release" bug). These are cheap 304s, and the Flutter service worker still
  # serves them offline.
  <FilesMatch "(^index\.html$|^flutter_bootstrap\.js$|^flutter_service_worker\.js$|^main\.dart\.js$|\.json$)">
    Header set Cache-Control "no-cache, max-age=0, must-revalidate"
  </FilesMatch>

  # Static media / fonts / wasm change rarely; allow public caching so repeat
  # visits (and any future CDN) can serve them without a round-trip. The Flutter
  # service worker handles content-hash cache-busting on top of this.
  <FilesMatch "\.(ttf|otf|woff2?|png|jpe?g|webp|svg|gif|ico|wasm)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Pre-compressed wasm (see rewrite rules below): keep the wasm content type
  # and declare the applied encoding so browsers decompress transparently.
  <FilesMatch "\.wasm\.br$">
    ForceType application/wasm
    Header set Content-Encoding br
    Header append Vary Accept-Encoding
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
  <FilesMatch "\.wasm\.gz$">
    ForceType application/wasm
    Header set Content-Encoding gzip
    Header append Vary Accept-Encoding
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/wasm .wasm
  # .br/.gz are content-encoding suffixes here, not language/type hints.
  RemoveLanguage .br
  RemoveType .br .gz
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Useful, index-safe error document for paths outside the finite Flutter and
  # public-document route sets below. ErrorDocument preserves the original 404.
  ErrorDocument 404 /404.html

  # canvaskit.wasm is ~5.7MB and LiteSpeed does not compress application/wasm
  # dynamically. CI ships pre-compressed .wasm.br/.wasm.gz next to each .wasm;
  # serve those when the client advertises support (~1.3MB over the wire).
  RewriteCond %{HTTP:Accept-Encoding} br
  RewriteCond %{REQUEST_FILENAME} \.wasm$
  RewriteCond %{REQUEST_FILENAME}.br -f
  RewriteRule ^(.*)$ $1.br [QSA,L]

  RewriteCond %{HTTP:Accept-Encoding} gzip
  RewriteCond %{REQUEST_FILENAME} \.wasm$
  RewriteCond %{REQUEST_FILENAME}.gz -f
  RewriteRule ^(.*)$ $1.gz [QSA,L]

  # Avoid SPA rewrites serving index.html for missing source maps (noise in DevTools).
  RewriteCond %{REQUEST_URI} \.map$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  # Canonicalize the oldest map query alias in one hop. All other compact and
  # long-form share aliases are proxied to the public renderer, which returns a
  # single permanent redirect to the locale-aware canonical document.
  RewriteCond %{REQUEST_URI} ^/map/?$ [NC]
  RewriteCond %{QUERY_STRING} (^|&)marker=([^&]+) [NC]
  RewriteRule ^map/?$ /en/map/%2 [R=308,L,NE,QSD]

  # Public HTML, sitemaps, robots and legacy aliases are rendered by the
  # existing Node service. Route through the local fixed-origin PHP gateway so
  # shared LiteSpeed/cPanel hosting does not require a server-level External
  # App or mod_proxy privilege. The gateway accepts only this finite surface,
  # never forwards cookies/authentication, and preserves upstream status and
  # cache/security headers.
  RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
  RewriteRule ^(?:robots\.txt|sitemap\.xml|sitemaps/[^/]+\.xml)$ seo-proxy.php [L,QSA]

  RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
  RewriteRule ^(?:en|sl)(?:/.*)?$ seo-proxy.php [L,QSA]

  RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
  RewriteRule ^(?:a|u|e|x|p|c|n|m|artwork|artworks|profile|profiles|user|users|post|posts|event|events|exhibition|exhibitions|collection|collections|nft|nfts|collectible|collectibles|marker|markers|art-marker|art-markers)/[^/]+/?$ seo-proxy.php [L,QSA]

  # Explicit interactive-app namespace. Public landing pages link here, and
  # ShareDeepLinkParser understands both compact and localized paths after the
  # /app prefix. Root remains the established Flutter homepage.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^app(?:/.*)?$ index.html [L]

  RewriteRule ^$ index.html [L]

  # Preserve the existing finite Flutter route surface. Authentication,
  # settings, checkout and wallet pages stay interactive but are never exposed
  # as public SEO documents.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(?:main|map|community|home|explore|ar|artwork|exhibition|connect-wallet|wallet_connect|connect_wallet|import-wallet|sign-in|register|secure-account|verify-email(?:/success)?|forgot-password|reset-password|promotions|web3|wallet(?:/availability-node)?|settings(?:/availability-node)?|marketplace)/?$ index.html [L]

  # Unknown paths are real 404s, not indexable Flutter-shell soft 404s.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ - [R=404,L]
</IfModule>
