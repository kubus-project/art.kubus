<IfModule mod_headers.c>
  Header unset Content-Security-Policy
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://fonts.googleapis.com https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https: wss: blob:; media-src 'self' blob: data: https:; worker-src 'self' blob:; object-src 'none'; frame-src 'self' https://accounts.google.com;"

  # --- Caching ---------------------------------------------------------------
  # LiteSpeed defaults to "Cache-Control: private", which prevents any CDN/edge
  # caching and offers no benefit to repeat visits. Override explicitly.
  #
  # App entry points + version manifests must ALWAYS revalidate so a new deploy
  # is picked up immediately (prevents the classic "stale main.dart.js after
  # release" bug). These are cheap 304s, and the Flutter service worker still
  # serves them offline.
  <FilesMatch "(^index\.html$|^flutter_bootstrap\.js$|^flutter_service_worker\.js$|^main\.dart\.js$|\.json$)">
    Header set Cache-Control "no-cache, max-age=0, must-revalidate"
  </FilesMatch>

  # Static media / fonts / wasm change rarely; allow public caching so repeat
  # visits (and any future CDN) can serve them without a round-trip. The Flutter
  # service worker handles content-hash cache-busting on top of this.
  <FilesMatch "\.(ttf|otf|woff2?|png|jpe?g|webp|svg|gif|ico|wasm)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Pre-compressed wasm (see rewrite rules below): keep the wasm content type
  # and declare the applied encoding so browsers decompress transparently.
  <FilesMatch "\.wasm\.br$">
    ForceType application/wasm
    Header set Content-Encoding br
    Header append Vary Accept-Encoding
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
  <FilesMatch "\.wasm\.gz$">
    ForceType application/wasm
    Header set Content-Encoding gzip
    Header append Vary Accept-Encoding
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/wasm .wasm
  # .br/.gz are content-encoding suffixes here, not language/type hints.
  RemoveLanguage .br
  RemoveType .br .gz
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # canvaskit.wasm is ~5.7MB and LiteSpeed does not compress application/wasm
  # dynamically. CI ships pre-compressed .wasm.br/.wasm.gz next to each .wasm;
  # serve those when the client advertises support (~1.3MB over the wire).
  RewriteCond %{HTTP:Accept-Encoding} br
  RewriteCond %{REQUEST_FILENAME} \.wasm$
  RewriteCond %{REQUEST_FILENAME}.br -f
  RewriteRule ^(.*)$ $1.br [QSA,L]

  RewriteCond %{HTTP:Accept-Encoding} gzip
  RewriteCond %{REQUEST_FILENAME} \.wasm$
  RewriteCond %{REQUEST_FILENAME}.gz -f
  RewriteRule ^(.*)$ $1.gz [QSA,L]

  # Avoid SPA rewrites serving index.html for missing source maps (noise in DevTools).
  RewriteCond %{REQUEST_URI} \.map$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  # Canonicalize legacy share URLs before Flutter boots.
  RewriteCond %{REQUEST_URI} ^/map/?$ [NC]
  RewriteCond %{QUERY_STRING} (^|&)marker=([^&]+) [NC]
  RewriteRule ^map/?$ /m/%2 [R=301,L,NE,QSD]

  RewriteRule ^(?:marker|markers|art-marker|art-markers)/(.+)$ /m/$1 [R=301,L,NE]
  RewriteRule ^(?:artwork|artworks)/(.+)$ /a/$1 [R=301,L,NE]
  RewriteRule ^(?:profile|profiles|user|users)/(.+)$ /u/$1 [R=301,L,NE]
  RewriteRule ^(?:post|posts)/(.+)$ /p/$1 [R=301,L,NE]
  RewriteRule ^(?:event|events)/(.+)$ /e/$1 [R=301,L,NE]
  RewriteRule ^(?:exhibition|exhibitions)/(.+)$ /x/$1 [R=301,L,NE]
  RewriteRule ^(?:collection|collections)/(.+)$ /c/$1 [R=301,L,NE]
  RewriteRule ^(?:nft|nfts)/(.+)$ /n/$1 [R=301,L,NE]

  # Flutter web SPA deep links (e.g. /m/<id>): serve index.html for any
  # route that isn't a real file or directory.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>
