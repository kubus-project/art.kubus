{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: Cleanup stale machine test runners",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\cleanup_flutter_machine_test_processes.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Flutter: Safe test (focused community+desktop)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\safe_flutter_test.ps1",
        "test/community/community_subject_provider_test.dart",
        "test/community/community_subject_navigation_test.dart",
        "test/community/community_post_subject_parsing_test.dart",
        "test/widgets/desktop/desktop_shell_scope_test.dart"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Flutter: Safe test (all)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\safe_flutter_test.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
